-- ==================== 기능 변수 ====================
local WallbangEnabled = true
local SilentAimEnabled = true
local NoCoolTimeEnabled = true

-- No Cool Time
local function ApplyNoCoolTime(state)
    NoCoolTimeEnabled = state
    if not state then return end
    local patch = {
        AttackCooldown = 1e-9,
        UseDelay = 5e-9,
        Cooldown = 1e-9,
        HeavyAttackCooldown = 3e-9,
        SpinCooldown = 5e-9,
    }
    for key, val in pairs(patch) do
        pcall(function() setgc(key, val) end)
    end
end

-- Silent Aim
local function ToggleSilentAim(state)
    SilentAimEnabled = state
    -- (Silent Aim 로직은 이전과 동일)
    print("Silent Aim:", state and "ON" or "OFF")
end

-- Wallbang
local function ToggleWallbang(state)
    WallbangEnabled = state
    print("Wallbang:", state and "ON" or "OFF")
end

